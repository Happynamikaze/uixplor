{
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Frame-Options",
					"value": "SAMEORIGIN"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
				},
				{
					"key": "X-DNS-Prefetch-Control",
					"value": "on"
				}
			]
		}
	],
	"redirects": [
		{
			"source": "/phpmyadmin",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/.git",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/config",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/server.js",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/env",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/.env",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/wp-admin",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/wp-login.php",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/xmlrpc.php",
			"destination": "/404",
			"statusCode": 302
		},
		{
			"source": "/private",
			"destination": "/404",
			"statusCode": 302
		}
	]
}